# Copy to ~/.claude/.env and fill in values. Never commit .env itself.

# OpenAI API key — used by Codex review sidecars and deep-research OpenAI.
OPENAI_API_KEY=

# Perplexity API key — used by deep-research Perplexity.
PERPLEXITY_API_KEY=

# Gemini API key — used by deep-research Gemini.
GEMINI_API_KEY=
