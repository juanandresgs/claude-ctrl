{
  "_comment": "@decision DEC-BAZAAR-003: Provider registry for future-proofing — adding a new provider means adding an entry here plus a thin wrapper in scripts/lib/. No SKILL.md changes needed.",
  "providers": {
    "anthropic": {
      "env_key": "ANTHROPIC_API_KEY",
      "module": "anthropic_chat",
      "default_model": "claude-opus-4-6",
      "fallback_model": "claude-sonnet-4-6",
      "max_tokens": 4096,
      "role": ["ideator", "judge", "analyst"],
      "description": "Anthropic Claude — strong reasoning and structured output"
    },
    "openai": {
      "env_key": "OPENAI_API_KEY",
      "module": "openai_chat",
      "default_model": "gpt-5.2",
      "fallback_model": "gpt-4o",
      "max_tokens": 4096,
      "role": ["ideator", "judge", "analyst"],
      "description": "OpenAI GPT — broad knowledge and strong JSON mode"
    },
    "gemini": {
      "env_key": "GEMINI_API_KEY",
      "module": "gemini_chat",
      "default_model": "gemini-3.1-pro-preview",
      "fallback_model": "gemini-2.0-flash",
      "max_tokens": 4096,
      "role": ["ideator", "judge", "analyst"],
      "description": "Google Gemini — multimodal reasoning and large context"
    },
    "perplexity": {
      "env_key": "PERPLEXITY_API_KEY",
      "module": "perplexity_chat",
      "default_model": "sonar-deep-research",
      "fallback_model": "sonar-pro",
      "max_tokens": 4096,
      "role": ["obsessive"],
      "description": "Perplexity Sonar — live web search with citations"
    }
  },
  "archetype_assignments": {
    "methodical": "anthropic",
    "contrarian": "openai",
    "pattern-matcher": "gemini",
    "edge-case-hunter": "anthropic",
    "systems-thinker": "openai",
    "pragmatist": "anthropic",
    "visionary": "gemini",
    "risk-manager": "openai",
    "quant": "anthropic",
    "domain-obsessive": "anthropic",
    "search-obsessive": "perplexity",
    "analyst": "anthropic"
  }
}
