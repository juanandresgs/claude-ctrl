{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "summary",
    "detail",
    "findings",
    "next_steps"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "READY_FOR_REVIEWER",
        "TRY_AGAIN",
        "BLOCKED_BY_PLAN"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "detail": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Short tactical finding highlights. These are not outer-loop reviewer findings."
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
