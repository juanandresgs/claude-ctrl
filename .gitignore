# Claude Code Configuration .gitignore
# Runtime data excluded; intentional configuration tracked

# ═══════════════════════════════════════════════════════════
# RUNTIME DATA (regenerated by Claude Code, never commit)
# ═══════════════════════════════════════════════════════════

# API keys (central .env)
.env

# Session tracking
.session-decisions
.claude/

# Generated decision log (hook output, never commit)
DECISIONS.md

# Session data (runtime, regenerated per session)
sessions/

# Community status (runtime state, regenerated by hooks)
.community-status

# Observatory runtime artifacts (regenerated by observatory skill)
observatory/analysis-cache*.json
observatory/assessment-report.md
observatory/comparison-matrix.json
observatory/state.json.*-backup

# Large runtime directories
projects/
todos/
debug/
plugins/
cache/
file-history/
shell-snapshots/
paste-cache/
session-env/
statsig/
telemetry/
ide/
tasks/
chrome/
tmp/
fudge-traces/
traces/
# Allow test fixture trace directories (static, versioned regression anchors)
!tests/fixtures/traces/
!tests/fixtures/traces/**
image-cache/

# External tool data
.gemini-clipboard/

# Session history
history.jsonl
stats-cache.json

# Plan files (session-specific)
plans/

# Archive (recoverable deletions, not tracked)
.archive/
_archive/

# Statusline cache (regenerated by statusline.sh on every render)
.statusline-cache
.statusline-cache.tmp.*

# State database (runtime, regenerated by hooks)
state.json

# Mock gate strike counter (runtime, ephemeral per session)
.mock-gate-strikes

# Session lifecycle (regenerated per session, never commit)
.prompt-count-*
.session-start-epoch
.session-main-tokens
.session-token-history
.checkpoint-counter
.subagent-tracker
.subagent-tracker-*
.active-worktree-path*
.proof-status
.proof-status-*
.cwd-recovery-needed
.session-cost-history
.test-status

# Stop/session TTL markers (ephemeral, regenerated per session)
.stop-*

# Subagent token tracking (ephemeral, per-session accounting)
.subagent-tokens-*

# CI state files (ephemeral runtime state, never commit)
.ci-status-*
.ci-watch-*.lock

# Guardian/tester tracking (ephemeral runtime state)
.guardian-start-sha
.last-tester-trace

# Drift tracking files (runtime state, regenerated by hooks)
.doc-drift
.plan-drift

# Hook integrity checksums (regenerated by update-check.sh on startup)
.hook-checksums

# MCP auth cache (local runtime, user-specific)
mcp-needs-auth-cache.json

# Bazaar skill output directories (one-shot research output)
bazaar-*/

# Playwright MCP runtime directory
.playwright-mcp/


# MCP server configuration (local runtime, user-specific)
.mcp.json

# Agent findings (one-shot inter-agent delivery, deleted after injection)
.agent-findings

# Auto-update state (session-scoped, consumed by session-init.sh)
.update-status
.update-check.lock

# User preference: disable auto-updates (local toggle, not distributed)
.disable-auto-update

# Audit log (append-only session log, trimmed at session-end)
.audit-log

# Todo count cache (regenerated from GitHub API on every HUD call)
.todo-count

# Todo image attachments (local storage, not tracked)
todo-images/

# Git worktrees (feature isolation, never tracked)
.worktrees/

# Worktree roster (machine-local state, regenerated per registration)
.worktree-roster.tsv

# Worktree lockfile (runtime, created by implementer, deleted after session ends)
.claude-active

# Runtime state directory (flock locks, ephemeral per-session state)
state/

# Runtime output directories
backups/
research_output/

# ═══════════════════════════════════════════════════════════
# LOCAL OVERRIDES (user-specific, not tracked)
# ═══════════════════════════════════════════════════════════

CLAUDE.local.md
settings.local.json

# ═══════════════════════════════════════════════════════════
# OS / EDITOR (noise)
# ═══════════════════════════════════════════════════════════

.DS_Store
Thumbs.db
Desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# ═══════════════════════════════════════════════════════════
# TEMPORARY FILES
# ═══════════════════════════════════════════════════════════

*.tmp
*.log
*.bak
*.orig
*.rej

# ═══════════════════════════════════════════════════════════
# LANGUAGE-SPECIFIC (if scripts exist)
# ═══════════════════════════════════════════════════════════

# Python
__pycache__/
*.pyc
*.pyo
.Python

# Node.js
node_modules/
npm-debug.log*
yarn-error.log*
