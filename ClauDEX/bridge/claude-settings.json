{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Write",
      "Edit",
      "Task",
      "Glob",
      "Grep"
    ],
    "deny": [
      "NotebookEdit",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git checkout main*)",
      "Bash(git checkout master*)",
      "Bash(git branch -D *)",
      "Bash(rm -rf *)",
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/*credentials*)"
    ],
    "ask": [],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/hooks/claudex-submit-inject.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/hooks/pre-bash.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "{ cat; echo; } >> $HOME/.claude/runtime/dispatch-debug.jsonl",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/hooks/pre-agent.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "{ cat; echo; } >> $HOME/.claude/runtime/dispatch-debug.jsonl",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/hooks/pre-agent.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{ cat; echo; } >> $HOME/.claude/runtime/dispatch-debug.jsonl",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/hooks/subagent-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/hooks/claudex-stop-relay.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
