{
  "permissions": {
    "allow": [
      "Bash(awk *)",
      "Bash(basename *)",
      "Bash(cat *)",
      "Bash(cut *)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(du *)",
      "Bash(echo *)",
      "Bash(env *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(less *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(lsof *)",
      "Bash(pwd)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(rg *)",
      "Bash(sleep *)",
      "Bash(sort *)",
      "Bash(stat *)",
      "Bash(tail *)",
      "Bash(test *)",
      "Bash(tr *)",
      "Bash(uname)",
      "Bash(uname *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(whoami)",
      "Bash(git *)",
      "Bash(xargs *)",
      "Read",
      "Write",
      "Edit",
      "Task",
      "Glob",
      "Grep"
    ],
    "deny": [
      "NotebookEdit",
      "Bash(git checkout main*)",
      "Bash(git checkout master*)",
      "Bash(git branch -D *)",
      "Bash(rm -rf *)",
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/*credentials*)"
    ],
    "ask": [],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/hooks/claudex-submit-inject.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/hooks/pre-bash.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "{ cat; echo; } >> $HOME/.claude/runtime/dispatch-debug.jsonl",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/hooks/pre-agent.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "{ cat; echo; } >> $HOME/.claude/runtime/dispatch-debug.jsonl",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/hooks/pre-agent.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/hooks/post-bash.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{ cat; echo; } >> $HOME/.claude/runtime/dispatch-debug.jsonl",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/hooks/subagent-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/hooks/claudex-stop-relay.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
